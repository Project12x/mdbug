{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mdbug/config.schema.json",
  "title": "mdbug project config",
  "type": "object",
  "required": ["backends", "perf", "gate"],
  "additionalProperties": false,
  "properties": {
    "backends": {
      "type": "object",
      "required": ["default"],
      "properties": {
        "default": { "type": "string" },
        "blastem": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "path":       { "type": ["string", "null"] },
            "gdbPort":    { "type": "integer" },
            "gdb":        { "type": ["string", "null"] },
            "sampleMode": { "type": "string" },
            "frames":     { "type": "integer" },
            "screenshot": { "type": "string" }
          }
        },
        "emusplatter": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "path":       { "type": ["string", "null"] },
            "gdbPort":    { "type": "integer" },
            "gdb":        { "type": ["string", "null"] },
            "sampleMode": { "type": "string" },
            "frames":     { "type": "integer" },
            "screenshot": { "type": "string" }
          }
        }
      },
      "additionalProperties": true
    },
    "build": {
      "type": "object",
      "properties": {
        "command": { "type": "string" },
        "cwd":     { "type": "string" },
        "rom":     { "type": "string" },
        "elf":     { "type": "string" }
      },
      "additionalProperties": false
    },
    "perf": {
      "type": "object",
      "required": ["symbol", "count", "width", "fields"],
      "properties": {
        "symbol": { "type": "string" },
        "count":  { "type": "integer" },
        "width":  { "type": "string" },
        "trigger": {
          "type": "object",
          "properties": {
            "type":   { "type": "string" },
            "symbol": { "type": "string" }
          },
          "additionalProperties": false
        },
        "samples": { "type": "integer" },
        "skipSamples": { "type": "integer" },
        "preroll": {
          "type": "array",
          "items": { "type": "string" }
        },
        "doneFlag": {
          "type": "object",
          "properties": {
            "symbol": { "type": "string" },
            "value":  {}
          },
          "additionalProperties": false
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["index", "name", "aggregate", "unit", "gate"],
            "properties": {
              "index":     { "type": "integer" },
              "name":      { "type": "string" },
              "aggregate": { "type": "string", "enum": ["max", "last", "sum", "median", "p90", "range", "stdev", "mean_abs_delta", "periodicity"] },
              "unit":      { "type": "string" },
              "gate":      { "type": "boolean" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "screenshots": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "checkpoints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name":      { "type": "string" },
              "atSeconds": { "type": "number" },
              "atFrame":   { "type": "integer" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "watch": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "symbol"],
        "properties": {
          "name":   { "type": "string" },
          "symbol": { "type": "string", "description": "gdb lvalue (global); read as *(ctype*)&symbol" },
          "type":   { "type": "string", "enum": ["u8", "s8", "u16", "s16", "u32", "s32", "raw"],
                      "description": "C width for the read cast (default u16). 'raw' = no cast; symbol must be a fully-formed gdb expression. The cast makes the read work for minimal symbols (-O3/-flto) that lack a DWARF type." },
          "format": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "gate": {
      "type": "object",
      "required": ["baseline", "tolerance", "ceilings"],
      "properties": {
        "baseline":  { "type": "string" },
        "tolerance": { "type": "object" },
        "ceilings":  { "type": "object" },
        "validity": {
          "type": "object",
          "properties": {
            "requireNonzero": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "report": {
      "type": "object",
      "properties": {
        "outDir": { "type": "string" }
      },
      "additionalProperties": false
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "description": "PC-sampling profiler (mdbug.ps1 -Profile / analyzer.profile). Optional; the gate works without it.",
      "properties": {
        "symbolizer": { "type": "string", "enum": ["auto", "elf", "nm"], "default": "auto",
                        "description": "PC symbolization source. auto = prefer ELF when pyelftools + build.elf resolve, else the nm symbol.txt floor; elf = require the rich path; nm = always legacy." },
        "format":     { "type": "string", "enum": ["md", "folded", "speedscope", "perfetto"], "default": "md",
                        "description": "Report format. md = flame table; folded/speedscope/perfetto are interchange artifacts (carry inline call frames when DWARF is present)." },
        "elf":        { "type": "string", "description": "ROM ELF for true-range/inline symbolization (e.g. out/rom.out). Defaults to build.elf." },
        "rom":        { "type": "string", "description": "Raw ROM bytes for --disasm (e.g. out/rom.bin). Defaults to build.rom." },
        "symbols":    { "type": "string", "description": "nm symbol.txt fallback path. Defaults to <dir of elf>/symbol.txt." },
        "symbol":     { "type": "string", "description": "Hot symbol to disassemble + weight per instruction (--disasm). Skipped cleanly if capstone/ELF/ROM absent." },
        "route":      { "type": "string", "description": "Scenario label for the report header." },
        "top":        { "type": "integer", "description": "Limit the flame table to the top N functions (0 = all)." },
        "trigger":    { "type": "string", "description": "gdb break symbol fired once per frame to step the ring fill (default dbg_perf_tick)." },
        "armFrame":   { "type": "integer", "description": "Documentation only (no harness effect): mirrors the ROM's compiled-in PC_SAMPLE_ARM_FRAME -- the settle frames before the ring is meaningful. Change it in the build, not here." },
        "continues":  { "type": "integer", "description": "Number of break-continues to fill the ring before dumping (PROFILING.md TL;DR uses ~82)." },
        "max":        { "type": "integer", "description": "PC_SAMPLE_MAX ring size; the count in x/<MAX>xw &g_pc_samples (default 1024)." },
        "romMin":     { "type": "integer", "description": "Lower PC bound for the ROM-range sample filter (default 512 = 0x200 entry)." },
        "romMax":     { "type": "integer", "description": "Upper PC bound for the ROM-range filter (default 2097152 = 0x200000)." },
        "out":        { "type": "string", "description": "Profile report path. Default <outDir>/profile.<ext>." }
      }
    }
  }
}
